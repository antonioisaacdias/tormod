# Tormod server — example environment. Copy to .env (never commit a real one).
# Auth is single-user (register on first run) over an httpOnly session cookie.
# There is NO bearer token anymore.

# Listening port (binds 127.0.0.1).
PORT=8790

# Brain: "claude" drives the real Claude Code via the Agent SDK; "fake" is LLM-free.
TORMOD_BRAIN=fake
# Working directory for the brain (used with TORMOD_BRAIN=claude).
# TORMOD_CWD=/home/odin

# SQLite file (holds audit, sessions, users and settings).
TORMOD_AUDIT=./tormod-audit.db
# Settings SQLite file (defaults to TORMOD_AUDIT).
# TORMOD_SETTINGS=./tormod-audit.db

# Origin-adaptive 2FA: requests from these CIDRs are "local" (TOTP skipped).
# Default: 192.168.0.0/24,10.0.0.0/24,127.0.0.1/32,::1/128
# TORMOD_TRUSTED_CIDRS=192.168.0.0/24,10.0.0.0/24,127.0.0.1/32,::1/128

# Proxy IP whose X-Forwarded-For is trusted for client-IP resolution.
# Set this (and ensure the app is only reachable externally via this proxy)
# before exposing Tormod to the internet.
# TORMOD_TRUSTED_PROXY=

# Session cookie Secure flag. Keep true behind HTTPS; set false for plain-HTTP LAN dev.
TORMOD_COOKIE_SECURE=true

# Session lifetime in days.
TORMOD_SESSION_TTL_DAYS=30
